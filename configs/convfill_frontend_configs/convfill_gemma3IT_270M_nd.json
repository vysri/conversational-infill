{
  "model_name": "google/gemma-3-270m-it",
  "backend": "hf",
  "convfill_hf_pretrained_path": "vysri/gemma3-270m-IT-ConvFill",
  "convfill_hf_mlx_pretrained_path":"vysri/gemma3-270m-IT-ConvFill_mlx_q8",
  "dataset_path": "your dataset path here",
  "dataset_mode": "full",
  "platform": "gpu",
  "wanb_project": "convfill",
  "training_split_percent": 0.9,

  "add_special_tokens": true,
  "special_tokens": {
    "additional_special_tokens": ["<sil>"]
  },

  "boundary_tokens": {
    "USER_START": "<start_of_turn>user\n",
    "KNOWLEDGE_START": "<start_of_turn>knowledge\n",
    "ASSN_START": "<start_of_turn>model\n",
    "END": "<end_of_turn>\n"
  },

  "training_config": {
    "batch_size": 4,
    "accumulate_grad_batches": 4,
    "num_epochs": 1,
    "learning_rate": 1e-4,
    "weight_decay": 0.01,
    "warmup_steps": 200,
    "scheduler": "cosine",
    "val_check_interval": 0.25
  },

  "logging_config": {
    "log_every_n_steps": 10
  },

  "checkpoint_config": {
    "every_n_train_steps": 50
  }
}