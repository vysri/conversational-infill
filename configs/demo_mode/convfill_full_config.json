{
    "frontend_model_config_path": "configs/convfill_frontend_configs/convfill_qwen3_0.6B_nd.json",
    "frontend_checkpoint_dir": "final_model_checkpoints",
    "backend_model_name": "claude-opus-4-7",
    "backend_model_mode": "claude",
    "num_history_turns": 1,
    "tts_mode": "say",
    "modes": {
        "normal": {
            "backend_prompt_template_file": "configs/convfill_backend_prompts/convfill_backend_template_conv.txt"
        },
        "rag": {
            "backend_prompt_template_file": "configs/convfill_backend_prompts/convfill_backend_template_rag_conv.txt",
            "task_specific_config": {
                "rag_index": "src/inference/rag/uw_phd.index",
                "rag_chunks": "src/inference/rag/uw_chunks.json",
                "reranker_model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
                "embedding_model": "text-embedding-3-large"
            }
        },
        "mcp": {
            "backend_prompt_template_file": "configs/convfill_backend_prompts/convfill_backend_template_mcp_conv.txt",
            "task_specific_config": {
                "mcp_servers": [
                    {
                        "name": "mail",
                        "transport": "stdio",
                        "command": "docker",
                        "args": ["exec", "-i", "gmail-mcp", "mail-mcp"],
                        "env": {}
                    }
                ],
                "max_tool_iterations": 4
            }
        }
    }
}
